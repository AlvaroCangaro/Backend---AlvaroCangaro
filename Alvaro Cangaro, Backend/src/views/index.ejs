<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.0-beta1/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-0evHe/X+R7YkIZDRvuzKMRqM+OrBnVFBL6DOitfPri4tjfHxaWutUpFmBp4vmVor" crossorigin="anonymous">
    <title>Apple Arg</title>
</head>
<body>

    <h2 style="text-align: center;">Cargar un producto</h2>
    <form action="/api/productos" method="POST" style="max-width: 50%; margin-top: 3%; margin-left: 25%;"> 
        <div class="mb-3">
            <label class="form-label">Producto</label>
            <input type="text" name="title" class="form-control">
        </div>
        <div class="mb-3">
            <label class="form-label">Precio</label>
            <input type="number" name="price" class="form-control">
        </div>
        <div class="mb-3">
            <label class="form-label">Imagen URL</label>
            <input type="text" name="thumbnail" class="form-control">
        </div>
        <button type="submit" class="btn btn-primary">Cargar Producto</button>
        <button class="btn btn-primary"><a href="/api/productos" style="text-decoration: none; color: white;">Ver productos</a></button>
    </form>    
    
</body>
</html>